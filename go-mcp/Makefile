# elering-dashboard-mcp build. GENERATED by @voxgig/sdkgen go-mcp target.
BINARY := elering-dashboard-mcp
DIST := dist
GOOS := $(shell go env GOOS)
GOARCH := $(shell go env GOARCH)
EXT := $(if $(filter windows,$(GOOS)),.exe,)

.PHONY: build build-all clean

# Native build for the current machine -> dist/<os>-<arch>/elering-dashboard-mcp.
build:
	go build -o $(DIST)/$(GOOS)-$(GOARCH)/$(BINARY)$(EXT) .

# Cross-compiled release binaries: three desktop OSes x amd64/arm64, each named
# elering-dashboard-mcp (+ .exe on windows) inside its own dist/<os>-<arch>/ folder.
build-all: clean
	GOOS=linux   GOARCH=amd64 go build -o $(DIST)/linux-amd64/$(BINARY) .
	GOOS=linux   GOARCH=arm64 go build -o $(DIST)/linux-arm64/$(BINARY) .
	GOOS=darwin  GOARCH=amd64 go build -o $(DIST)/darwin-amd64/$(BINARY) .
	GOOS=darwin  GOARCH=arm64 go build -o $(DIST)/darwin-arm64/$(BINARY) .
	GOOS=windows GOARCH=amd64 go build -o $(DIST)/windows-amd64/$(BINARY).exe .
	GOOS=windows GOARCH=arm64 go build -o $(DIST)/windows-arm64/$(BINARY).exe .

clean:
	rm -rf $(DIST) $(BINARY) go-mcp
